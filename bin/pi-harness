#!/usr/bin/env bash
set -euo pipefail

CALLER_CWD="$PWD"
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "${PI_HARNESS_DISABLE_RESOLVE:-0}" != "1" && "${1:-}" != "start" && -f "$ROOT/scripts/resolve-harness.mjs" ]]; then
  RESOLVED_HARNESS="$(node "$ROOT/scripts/resolve-harness.mjs" --cwd "$PWD" 2>/dev/null || true)"
  if [[ -n "$RESOLVED_HARNESS" && "$RESOLVED_HARNESS" != "$ROOT" && -x "$RESOLVED_HARNESS/bin/pi-harness" ]]; then
    export PI_HARNESS_DISABLE_RESOLVE=1
    exec "$RESOLVED_HARNESS/bin/pi-harness" "$@"
  fi
fi

HARNESS_ROOT="$ROOT"
PROJECT_CONFIG="$HARNESS_ROOT/harness.project.json"
PROJECT_ROOT_FROM_CONFIG=""
if [[ -f "$PROJECT_CONFIG" ]]; then
  PROJECT_ROOT_FROM_CONFIG="$(node -e '
const fs = require("fs");
try {
  const file = process.argv[1];
  const data = JSON.parse(fs.readFileSync(file, "utf8"));
  if (data && typeof data.projectRoot === "string") process.stdout.write(data.projectRoot);
} catch {}
' "$PROJECT_CONFIG")"
fi

if [[ -n "${PI_HARNESS_PROJECT_ROOT:-}" ]]; then
  PROJECT_ROOT="$(cd "$PI_HARNESS_PROJECT_ROOT" && pwd)"
elif [[ -n "$PROJECT_ROOT_FROM_CONFIG" ]]; then
  PROJECT_ROOT="$(cd "$PROJECT_ROOT_FROM_CONFIG" && pwd)"
elif [[ "$(basename "$HARNESS_ROOT")" == ".pi-harness" ]]; then
  PROJECT_ROOT="$(cd "$HARNESS_ROOT/.." && pwd)"
else
  PROJECT_ROOT="$HARNESS_ROOT"
fi

mkdir -p "$HARNESS_ROOT/.pi-agent" "$HARNESS_ROOT/state/sessions" "$HARNESS_ROOT/state/tasks"

export PI_HARNESS_ROOT="$HARNESS_ROOT"
export PI_HARNESS_PROJECT_ROOT="$PROJECT_ROOT"
export PI_CODING_AGENT_DIR="${PI_CODING_AGENT_DIR:-$HARNESS_ROOT/.pi-agent}"

case "${1:-}" in
  start)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/start-project.mjs --target "$CALLER_CWD" "$@"
    ;;
  adopt)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/adopt-project.mjs --target "$CALLER_CWD" "$@"
    ;;
  setup)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/setup-wizard.mjs "$@"
    ;;
  bootstrap)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/bootstrap.mjs "$@"
    ;;
  next|learn|check|ready|done|checks|review-policy|proof|more|run-long|resume-long|long-run|run-long-heartbeat|run-long-checkpoint)
    COMMAND="$1"
    shift
    cd "$HARNESS_ROOT"
    case "$COMMAND" in
      done)
        exec node scripts/done-task.mjs "$@"
        ;;
      checks)
        exec node scripts/project-checks.mjs "$@"
        ;;
      review-policy)
        exec node scripts/review-policy.mjs "$@"
        ;;
      proof)
        exec node scripts/proof-ledger.mjs "$@"
        ;;
      more)
        exec node scripts/harness-more.mjs "$@"
        ;;
      run-long)
        exec node scripts/long-run.mjs plan "$@"
        ;;
      resume-long)
        exec node scripts/long-run.mjs resume "$@"
        ;;
      long-run)
        exec node scripts/long-run.mjs "$@"
        ;;
      run-long-heartbeat)
        exec node scripts/long-run.mjs heartbeat "$@"
        ;;
      run-long-checkpoint)
        exec node scripts/long-run.mjs checkpoint "$@"
        ;;
      *)
        exec node scripts/harnessctl.mjs "$COMMAND" "$@"
        ;;
    esac
    ;;
  harness)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/harnessctl.mjs "$@"
    ;;
  gates)
    shift
    cd "$HARNESS_ROOT"
    exec npm run gates -- "$@"
    ;;
  package-doctor)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/package-harness.mjs doctor "$@"
    ;;
  statusline)
    shift
    cd "$HARNESS_ROOT"
    exec node scripts/harness-more.mjs statusline "$@"
    ;;
  local-llm)
    shift
    case "${1:-}" in
      detect|doctor|prompt)
        cd "$HARNESS_ROOT"
        exec node scripts/local-llm.mjs "$@"
        ;;
    esac
    export PI_HARNESS_LOCAL_LLM=1
    export PI_HARNESS_ASSIST=local-llm
    ;;
  models|login|auth)
    shift
    export PI_HARNESS_ASSIST=models
    ;;
  team|subagents)
    shift
    export PI_HARNESS_ENABLE_PROJECT_PACKAGES=1
    export PI_HARNESS_ASSIST=team
    ;;
  research|web|mcp)
    shift
    export PI_HARNESS_ENABLE_PROJECT_PACKAGES=1
    export PI_HARNESS_ASSIST=research
    ;;
  memory)
    shift
    case "${1:-}" in
      add|import|search|list|review|forget|prune|doctor)
        cd "$HARNESS_ROOT"
        exec node scripts/memory.mjs "$@"
        ;;
    esac
    export PI_HARNESS_ASSIST=memory
    ;;
  brief|task)
    shift
    export PI_HARNESS_ASSIST=brief
    ;;
esac

LOCAL_PI="$HARNESS_ROOT/node_modules/.bin/pi"
if [[ -x "$LOCAL_PI" ]]; then
  PI_BIN="$LOCAL_PI"
else
  PI_BIN="$(command -v pi || true)"
fi
if [[ -z "${PI_BIN:-}" ]]; then
  echo "Pi CLI not found. Run $HARNESS_ROOT/bin/pi-harness setup --apply --install, then retry." >&2
  exit 1
fi

cd "$HARNESS_ROOT"

case "${1:-}" in
  install|remove|uninstall|update|list|config)
    exec "$PI_BIN" "$@"
    ;;
esac

cd "$PROJECT_ROOT"

ARGS=(--session-dir "$HARNESS_ROOT/state/sessions")

if [[ "${PI_HARNESS_INHERIT_USER_RESOURCES:-0}" != "1" ]]; then
  if [[ "${PI_HARNESS_ENABLE_PROJECT_PACKAGES:-0}" == "1" ]]; then
    ARGS+=(
      --no-skills
      --skill "$HARNESS_ROOT/.pi/skills/harness"
      --no-prompt-templates
      --prompt-template "$HARNESS_ROOT/.pi/prompts"
      --no-themes
    )
  else
    ARGS+=(
      --no-extensions
      --extension "$HARNESS_ROOT/.pi/extensions/harness/index.ts"
      --no-skills
      --skill "$HARNESS_ROOT/.pi/skills/harness"
      --no-prompt-templates
      --prompt-template "$HARNESS_ROOT/.pi/prompts"
      --no-themes
    )
  fi
fi

exec "$PI_BIN" "${ARGS[@]}" "$@"
